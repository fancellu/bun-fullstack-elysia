{
  "name": "bun-fullstack-elysia",
  "version": "1.0",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "audit": "bun audit",
    "fullstack:dev": "bun run --watch src/backend/index.ts",
    "start:prod": "bun run src/backend/index.ts --prod",
    "build:fe:prod": "bun run build.ts --production",
    "build:be": "bun build --compile --target bun --define process.env.NODE_ENV=\"'production'\" --outfile server src/backend/index.ts",
    "build:be:linux": "bun build --compile --target=bun-linux-x64 --define process.env.NODE_ENV=\"'production'\" src/backend/index.ts --outfile server-linux",
    "build:all": "bun run build:fe:prod && bun run build:be && bun run build:be:linux",
    "start:win:prod": "./server.exe",
    "start:linux:prod": "./server-linux",
    "knip": "knip --dependencies"
  },
  "dependencies": {
    "@elysiajs/static": "latest",
    "@elysiajs/swagger": "^1.3.1",
    "@radix-ui/react-slot": "^1.2.4",
    "bun-types": "latest",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "elysia": "latest",
    "knip": "^6.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "bun-plugin-tailwind": "^0.1.2"
  },
  "module": "src/backend/index.ts"
}
