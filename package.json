{
  "name": "bun-fullstack-elysia",
  "version": "1.0",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "audit": "bun audit",
    "fullstack:dev": "bun run --watch src/backend/index.ts",
    "start:prod": "bun run src/backend/index.ts --prod",
    "build:be": "bun build --compile --target bun --define process.env.NODE_ENV=\"'production'\" --outfile server src/backend/index.ts",
    "build:be:linux": "bun build --compile --target=bun-linux-x64 --define process.env.NODE_ENV=\"'production'\" src/backend/index.ts --outfile server-linux",
    "build:fe": "bun build public/index.html --outdir ./public/dist",
    "build:fe:min": "bun build public/index.html --outdir ./public/dist --minify",
    "build:fe:min:prod": "bun build public/index.html --outdir ./public/dist --production",
    "build:all": "bun run build:be && bun run build:be:linux && bun run build:fe:min",
    "start:win:prod": "./server",
    "start:linux:prod": "./server-linux"
  },
  "dependencies": {
    "@elysiajs/static": "latest",
    "@elysiajs/swagger": "^1.3.1",

    "elysia": "latest",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "bun-plugin-tailwind": "^0.1.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "bun-types": "latest",
    "concurrently": "^9.2.1"
  },
  "module": "src/backend/index.ts"
}
